  "components": {
    "schemas": {
      "CreateArticleDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the article",
            "example": "My First Article"
          },
          "content": {
            "type": "string",
            "description": "The content of the article",
            "example": "Hello World content..."
          },
          "published": {
            "type": "boolean",
            "description": "Publish status",
            "default": false
          }
        },
        "required": [
          "title",
          "content",
          "published"
        ]
      },
      "Article": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "object",
            "nullable": true
          },
          "published": {
            "type": "boolean"
          },
          "userId": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "published",
          "userId"
        ]
      },
      "UpdateArticleDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the article",
            "example": "My First Article"
          },
          "content": {
            "type": "string",
            "description": "The content of the article",
            "example": "Hello World content..."
          },
          "published": {
            "type": "boolean",
            "description": "Publish status",
            "default": false
          }
        }
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "test@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password"
          },
          "name": {
            "type": "string",
            "description": "The name of the user",
            "example": "John Doe"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "jobTitle": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "aboutMe": {
            "type": "string"
          },
          "profilePicture": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "password",
          "updatedAt"
        ]
      },
      "SignInDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "test@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "test@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password"
          },
          "name": {
            "type": "string",
            "description": "The name of the user",
            "example": "John Doe"
          },
          "jobTitle": {
            "type": "string",
            "description": "The job title of the user",
            "example": "Software Engineer"
          },
          "location": {
            "type": "string",
            "description": "The location of the user",
            "example": "New York, NY"
          },
          "company": {
            "type": "string",
            "description": "The company of the user",
            "example": "Google"
          },
          "aboutMe": {
            "type": "string",
            "description": "The about me of the user",
            "example": "I am a software engineer"
          },
          "profilePicture": {
            "type": "string",
            "description": "The profile picture URL of the user",
            "example": "https://example.com/profile.jpg"
          }
        }
      }
    }
